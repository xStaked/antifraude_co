{
  "name": "@sn8/database",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "db:generate": "node ../../scripts/run-prisma.js generate --schema packages/database/prisma/schema.prisma",
    "db:migrate": "node ../../scripts/run-prisma.js migrate dev --schema packages/database/prisma/schema.prisma",
    "db:studio": "node ../../scripts/run-prisma.js studio --schema packages/database/prisma/schema.prisma",
    "db:push": "node ../../scripts/run-prisma.js db push --schema packages/database/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@sn8/typescript-config": "workspace:*",
    "prisma": "^6.5.0",
    "typescript": "^5.8.2"
  }
}
