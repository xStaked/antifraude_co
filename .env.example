# Database
DATABASE_URL="postgresql://sn8:sn8local@localhost:5432/antifraude?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# S3 / R2 / MinIO
# Para Cloudflare R2:
#   - Account ID: lo encuentras en el dashboard de R2
#   - Access Key: creas en R2 > Manage R2 API Tokens
#   - Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   - Public URL: https://<bucket>.<account_id>.r2.dev (o tu dominio custom)
S3_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_ACCESS_KEY_ID="<TU_ACCESS_KEY_ID>"
S3_SECRET_ACCESS_KEY="<TU_SECRET_ACCESS_KEY>"
S3_BUCKET_NAME="antifraude-evidence"
S3_PUBLIC_URL="https://<BUCKET_NAME>.<ACCOUNT_ID>.r2.dev"

# Security
JWT_SECRET="change-me-in-production-min-32-chars"
TURNSTILE_SECRET_KEY="1x0000000000000000000000000000000AA"

# App
PUBLIC_WEB_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000AA"

# Google AI (Gemini) - Para detección de comprobantes editados con IA
GOOGLE_API_KEY=
