{
  "name": "antifraude",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate",
    "db:push": "node scripts/run-prisma.js db push --schema packages/database/prisma/schema.prisma",
    "db:migrate": "turbo run db:migrate",
    "db:studio": "turbo run db:studio",
    "postinstall": "node scripts/setup-prisma.js"
  },
  "devDependencies": {
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@10.6.2"
}
