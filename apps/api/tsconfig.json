{
  "extends": "@sn8/typescript-config/nestjs.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": "./",
    "noEmit": false,
    "preserveSymlinks": true,
    "paths": {
      "@/*": ["src/*"],
      "@prisma/client": ["../../node_modules/.prisma/client"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
